        {
          "title": "Introduction to Anatomy & Physiology",
          "durationMinutes": 25,
          "blocks": [
            {
              "type": "paragraph",
              "text": "Anatomy: study of the structure of the body."
            },
            {
              "type": "paragraph",
              "text": "Physiology: study of how the body functions."
            },
            {
              "type": "nested_bullet_list",
              "title": "Levels of Organization of the Human Body",
              "items": [
                {
                  "text": "Chemical Level - atoms and molecules."
                },
                {
                  "text": "Cellular Level - cells."
                },
                {
                  "text": "Tissue Level - groups of similar cells."
                },
                {
                  "text": "Organ Level - two or more tissues working together."
                },
                {
                  "text": "System Level - group of organs working together."
                },
                {
                  "text": "Organismic Level - the whole individual."
                }
              ]
            },
            {
              "type": "nested_bullet_list",
              "title": "Interrelationship of Body Systems",
              "items": [
                {
                  "text": "No body system works in isolation."
                },
                {
                  "text": "All systems are interconnected."
                },
                {
                  "text": "Each system supports others."
                },
                {
                  "text": "Goal: homeostasis - maintenance of stable internal environment."
                },
                {
                  "text": "Respiratory system brings in oxygen and removes carbon dioxide."
                },
                {
                  "text": "Circulatory system delivers oxygen to cells and carries carbon dioxide away."
                },
                {
                  "text": "Both systems work together to maintain life."
                }
              ]
            }
          ],
          "id": "basic-anatomy-slide-8"
        },
