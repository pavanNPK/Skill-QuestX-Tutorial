                ],
                [
                  "Lateral",
                  "Toward the side"
                ],
                [
                  "Proximal",
                  "Nearer to reference point"
                ],
                [
                  "Distal",
                  "Farther from reference point"
                ],
                [
                  "Superficial",
                  "Closer to surface"
                ],
                [
                  "Peripheral",
                  "Away from center"
                ]
              ]
            }
          ],
          "id": "basic-anatomy-slide-9"
        },
        {
          "title": "Body Movements",
          "durationMinutes": 20,
          "blocks": [
            {
              "type": "table",
              "columns": [
                "Movement",
                "Meaning"
              ],
              "rows": [
                [
                  "Abduction",
                  "Movement away from midline"
                ],
                [
                  "Adduction",
                  "Movement toward midline"
                ],
                [
                  "Flexion",
                  "Bending movement"
                ],
                [
                  "Extension",
                  "Straightening movement"
                ],
                [
                  "Rotation",
                  "Turning around an axis"
                ],
                [
                  "Circumduction",
                  "Circular movement of limb"
                ]
              ]
            }
          ],
          "id": "basic-anatomy-slide-10"
        },
        {
          "title": "Body Cavities",
          "durationMinutes": 25,
          "blocks": [
            {
              "type": "paragraph",
              "text": "Body cavities are spaces within the body that protect internal organs, support organs, and separate organs."
            },
            {
              "type": "nested_bullet_list",
              "items": [
                {
                  "text": "The body cavities are divided into two main groups",
                  "children": [
                    {
                      "text": "Dorsal Body Cavity"
                    },
                    {
                      "text": "Ventral Body Cavity"
                    }
                  ]
                },
                {
                  "text": "Dorsal Body Cavity: located at the back of the body",
                  "children": [
                    {
                      "text": "Cranial cavity: contains the brain."
                    },
                    {
                      "text": "Spinal (vertebral) cavity: contains the spinal cord."
                    }
                  ]
                },
                {
                  "text": "Ventral Body Cavity: located at the front of the body and divided by the diaphragm",
                  "children": [
                    {
                      "text": "Thoracic cavity: located above the diaphragm; contains two pleural cavities, mediastinum, and pericardial cavity."
                    },
                    {
                      "text": "Abdominopelvic cavity: located below the diaphragm."
                    },
                    {
                      "text": "Abdominal cavity: contains stomach, liver, spleen, pancreas, and intestines."
                    },
                    {
                      "text": "Pelvic cavity: contains urinary bladder, reproductive organs, and rectum."
                    }
                  ]
                }
              ]
            }
          ],
          "id": "basic-anatomy-slide-11"
        },
        {
          "title": "Abdominal Quadrants",
          "durationMinutes": 20,
          "blocks": [
            {
              "type": "paragraph",
              "text": "The abdomen is divided into four quadrants by a vertical line and a horizontal line crossing at the umbilicus (navel)."
            },
            {
              "type": "nested_bullet_list",
              "items": [
                {
                  "text": "Right Upper Quadrant (RUQ)",
                  "children": [
                    {
                      "text": "Liver (right lobe)"
                    },
                    {
                      "text": "Gallbladder"
                    },
                    {
                      "text": "Part of stomach"
                    },
                    {
                      "text": "Pancreas (head)"
                    },
                    {
                      "text": "Right kidney"
                    }
                  ]
                },
                {
                  "text": "Left Upper Quadrant (LUQ)",
                  "children": [
                    {
                      "text": "Stomach"
                    },
                    {
                      "text": "Spleen"
                    },
                    {
                      "text": "Left lobe of liver"
                    },
                    {
                      "text": "Pancreas (body & tail)"
                    },
                    {
                      "text": "Left kidney"
                    }
                  ]
                },
                {
                  "text": "Right Lower Quadrant (RLQ)",
                  "children": [
                    {
                      "text": "Appendix"
                    },
                    {
                      "text": "Cecum"
                    },
                    {
                      "text": "Small intestine"
                    },
                    {
                      "text": "Right ovary (female)"
                    }
                  ]
                },
                {
                  "text": "Left Lower Quadrant (LLQ)",
                  "children": [
                    {
                      "text": "Sigmoid colon"
                    },
                    {
                      "text": "Small intestine"
                    },
                    {
                      "text": "Left ovary (female)"
                    }
                  ]
                }
              ]
            }
          ],
          "id": "basic-anatomy-slide-12"
        },
        {
          "title": "Human Body Positions",
          "durationMinutes": 15,
          "blocks": [
            {
              "type": "nested_bullet_list",
              "items": [
                {
                  "text": "Prone: lying flat on the abdomen with the face downward."
                },
                {
                  "text": "Supine: lying flat on the back with the face upward."
                },
                {
                  "text": "Right Lateral Recumbent: lying on the right side of the body."
                },
                {
                  "text": "Left Lateral Recumbent: lying on the left side of the body."
                },
                {
                  "text": "Fowler's Position: semi-sitting position with the head and upper body elevated."
                },
                {
                  "text": "Trendelenburg Position: supine position with the head lower than the feet."
                }
              ]
            }
          ],
          "id": "basic-anatomy-slide-13"
        }
      ]
    },
