        {
          "title": "Word Building",
          "durationMinutes": 20,
          "blocks": [
            {
              "type": "paragraph",
              "text": "Medical terms are built by combining a root word with a prefix and/or suffix to create the appropriate meaning. In the examples, the root word nephr, meaning the functional unit of the kidney, is used to construct several different terms."
            },
            {
              "type": "paragraph",
              "text": "When two consonants fall together, a combining vowel is introduced to make pronunciation easier."
            },
            {
              "type": "table",
              "columns": [
                "Root Words",
                "Suffix",
                "Meaning",
                "Term"
              ],
              "rows": [
                [
                  "Nephr/o (Kidney)",
                  "-itis",
                  "Inflammation of the kidney",
                  "Nephritis"
                ],
                [
                  "Pyel/o (Renal pelvis), Nephr/o (Kidney)",
                  "-itis",
                  "Inflammation of renal pelvis and kidney",
                  "Pyelonephritis"
                ],
                [
                  "Nephr/o (Kidney)",
                  "-ectomy",
                  "Surgical removal of a kidney",
                  "Nephrectomy"
                ],
                [
                  "Hydr/o (Water/Fluid), Nephr/o (Kidney)",
                  "-osis",
                  "Abnormal condition of fluid in the kidney",
                  "Hydronephrosis"
                ],
                [
                  "Poly- (Many), Nephr/o (Kidney)",
                  "-itis",
                  "Inflammation affecting many areas of the kidney",
                  "Polynephritis"
                ]
              ]
            }
          ],
