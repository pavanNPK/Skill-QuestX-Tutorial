# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# MongoDB (use the same URL as Compass – Drivers format)
# If you see "querySrv EREFUSED" (DNS SRV blocked), either:
# 1) Use local MongoDB: MONGODB_URI=mongodb://localhost:27017/skillquestx
# 2) In Atlas: Connect → "Drivers" → copy the non-SRV "Direct connection" URI (uses host:port, not mongodb+srv)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skillquestx?retryWrites=true&w=majority

# Hostinger SMTP (use App Password if available)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=noreply@yourdomain.com
MAIL_PASSWORD=your-app-password-or-email-password
MAIL_FROM=SkillQuestX <noreply@yourdomain.com>

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:4200

# Web Push (optional – run: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Super Admin script (optional — run: node scripts/create-super-admin.js from server folder)
# SA_EMAIL=superadmin@skillquestx.com
# SA_PASSWORD=ChangeMe@123
# SA_FIRST_NAME=Super
# SA_LAST_NAME=Admin
